{
  "expo": {
    "name": "delivery-staff-app",
    "slug": "delivery-staff-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow SwiftDeliver to take photos for proof of delivery"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SwiftDeliver to scan delivery barcodes"
        }
      ]
    ],
    "scheme": "deliveryapp"
  }
}
